<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos</title>
<meta name="description" content="Lumos — Kıbrıs yayını" />
</head>
<body>
<div class="page">
	<div class="flag-card" role="img" aria-label="Kuzey Kıbrıs bayrağına benzer düzen: üst ve alt kırmızı şerit, ortada beyaz alan ve kırmızı ay-yıldız">
		<div class="flag-stripe flag-stripe--top" aria-hidden="true"></div>
		<div class="flag-field">
			<div class="emblem" aria-hidden="true">
				<span class="crescent"></span>
				<span class="star"></span>
			</div>
		</div>
		<div class="flag-stripe flag-stripe--bottom" aria-hidden="true"></div>
	</div>
	<h1 class="title">Lumos</h1>
	<p class="tagline">Kıbrıs yayını aktif.</p>
</div>
<style is:global>
	:root {
		--tr-red: #c8102e;
		--paper: #ffffff;
		--ink: #141414;
		--muted: #3d3d3d;
		--stage: #1c1c1e;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: var(--stage);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(1.25rem, 4vw, 1.75rem);
		padding: clamp(1rem, 4vw, 2rem);
		text-align: center;
	}

	/* Beyaz bayrak kartı — ana odak */
	.flag-card {
		width: min(92vw, 22rem);
		max-width: 100%;
		border-radius: 10px;
		overflow: hidden;
		background: var(--paper);
		border: 2px solid rgba(255, 255, 255, 0.25);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.2),
			0 20px 50px rgba(0, 0, 0, 0.45),
			0 6px 16px rgba(200, 16, 46, 0.25);
	}

	.flag-stripe {
		height: clamp(2.75rem, 9vw, 4.25rem);
		min-height: 2.75rem;
		background: var(--tr-red);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
	}

	.flag-field {
		min-height: clamp(11rem, 38vw, 15rem);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 1.75rem) clamp(0.75rem, 3vw, 1.25rem);
		background: var(--paper);
	}

	.emblem {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(0.35rem, 2vw, 0.65rem);
		transform: scale(1);
	}

	/* Ay — ölçek büyütüldü */
	.crescent {
		display: block;
		width: clamp(4rem, 18vw, 5.5rem);
		height: clamp(4rem, 18vw, 5.5rem);
		border-radius: 50%;
		background: var(--tr-red);
		box-shadow: clamp(0.65rem, 3.5vw, 1.05rem) 0 0 0 var(--paper);
		transform: rotate(-18deg);
		flex-shrink: 0;
	}

	/* Yıldız — ölçek büyütüldü */
	.star {
		display: block;
		width: clamp(3.25rem, 14vw, 4.25rem);
		height: clamp(3.25rem, 14vw, 4.25rem);
		background: var(--tr-red);
		clip-path: polygon(
			50% 0%,
			61% 35%,
			100% 35%,
			69% 59%,
			82% 100%,
			50% 74%,
			18% 100%,
			31% 59%,
			0% 35%,
			39% 35%
		);
		margin-left: clamp(-0.2rem, -1vw, -0.05rem);
		flex-shrink: 0;
	}

	.title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
	}

	.tagline {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.78);
		max-width: 22rem;
	}

</style>
</body>
</html>
