<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos</title>
<meta name="description" content="Lumos — Kıbrıs yayını" />
</head>
<body>
<div class="page">
	<div class="flag-card" role="img" aria-label="Üst ve alt ince kırmızı şeritler, ortada beyaz alan ve ay-yıldız">
		<div class="flag-stripe flag-stripe--top" aria-hidden="true"></div>
		<div class="flag-field">
			<div class="emblem-wrap">
				<!--
				  Hilal: kırmızı tam daire + maske (siyah daire) ile beyaz alanı “ısırmış” gerçek hilal.
				  Sol tarafta kalır; yıldız sağda, küçük ve ayrı.
				-->
				<svg class="emblem-svg" viewBox="0 0 240 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
					<defs>
						<mask id="lumos-moon-mask">
							<rect width="240" height="80" fill="white" />
							<!-- Maske sağdan büyük ısırık: dolu disk değil, ince hilal -->
							<circle cx="118" cy="40" r="22.5" fill="black" />
						</mask>
					</defs>
					<circle cx="62" cy="40" r="27" fill="#c8102e" mask="url(#lumos-moon-mask)" />
					<g transform="translate(168 40) scale(0.36) rotate(-16) translate(-76 -36)">
						<path
							fill="#c8102e"
							d="M 76 24.5 L 78.7 32.28 L 86.94 32.45 L 80.37 37.42 L 82.76 45.3 L 76 40.6 L 69.24 45.3 L 71.63 37.42 L 65.06 32.45 L 73.29 32.28 Z"
						/>
					</g>
				</svg>
			</div>
		</div>
		<div class="flag-stripe flag-stripe--bottom" aria-hidden="true"></div>
	</div>
	<h1 class="title">Lumos</h1>
	<p class="tagline">Kıbrıs yayını aktif.</p>
</div>
<style is:global>
	:root {
		--tr-red: #c8102e;
		--paper: #ffffff;
		--ink: #141414;
		--stage: #121214;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: var(--stage);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(1.25rem, 4vw, 1.75rem);
		padding: clamp(1rem, 4vw, 2rem);
		text-align: center;
	}

	/* ~3:2 yatay bayrak; masaüstü max 420px, mobil max 86vw */
	.flag-card {
		display: grid;
		grid-template-rows: 0.11fr 1fr 0.11fr;
		width: min(86vw, 420px);
		aspect-ratio: 3 / 2;
		border-radius: 8px;
		overflow: hidden;
		border: 2px solid rgba(255, 255, 255, 0.32);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 16px 40px rgba(0, 0, 0, 0.45);
		background: var(--paper);
	}

	.flag-stripe {
		background: var(--tr-red);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
	}

	.flag-field {
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--paper);
		min-height: 0;
		padding: 0 4%;
	}

	.emblem-wrap {
		width: 92%;
		max-width: 21rem;
		margin: 0 auto;
	}

	.emblem-svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
	}

	.tagline {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.82);
		max-width: 22rem;
	}

</style>
</body>
</html>
