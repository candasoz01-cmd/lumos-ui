<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos</title>
<meta name="description" content="Lumos — Kıbrıs yayını" />
</head>
<body>
<div class="page">
	<div class="flag-card" role="img" aria-label="KKTC tarzı bayrak: üst-alt kırmızı şerit, ortada hilal ve yıldız">
		<svg
			class="flag-svg"
			viewBox="0 0 300 200"
			width="300"
			height="200"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
			preserveAspectRatio="xMidYMid meet"
		>
			<defs>
				<clipPath id="lumos-white-band">
					<rect x="0" y="22" width="300" height="156" />
				</clipPath>
				<!--
				  Hilal: kırmızı disk + maske — maske merkezi kırmızı merkeze yakın,
				  r yeterince büyük ki merkez maskelenir (dolgun top kalmaz).
				-->
				<mask id="lumos-hilal-mask">
					<rect width="300" height="200" fill="white" />
					<circle cx="118" cy="100" r="36" fill="black" />
				</mask>
			</defs>
			<!-- Zemin -->
			<rect width="300" height="200" fill="#ffffff" />
			<!-- Üst / alt şerit (~%11, simetrik) -->
			<rect x="0" y="0" width="300" height="22" fill="#c8102e" />
			<rect x="0" y="178" width="300" height="22" fill="#c8102e" />
			<!-- Ay-yıldız yalnızca beyaz bantta -->
			<g clip-path="url(#lumos-white-band)">
				<circle cx="88" cy="100" r="38" fill="#c8102e" mask="url(#lumos-hilal-mask)" />
				<path
					fill="#c8102e"
					transform="rotate(-15 215 100)"
					d="M 215.00 78.00 L 220.29 92.72 L 235.92 93.20 L 223.56 102.78 L 227.93 117.80 L 215.00 109.00 L 202.07 117.80 L 206.44 102.78 L 194.08 93.20 L 209.71 92.72 Z"
				/>
			</g>
		</svg>
	</div>
	<div class="skull-mark" aria-hidden="true">
		<svg class="skull-svg" viewBox="0 0 24 28" xmlns="http://www.w3.org/2000/svg">
			<path
				fill="currentColor"
				d="M12 4C7.6 4 4 7.8 4 12.5c0 2.4 1.2 4.6 3 5.8V26h14v-7.7c1.8-1.2 3-3.4 3-5.8C24 7.8 20.4 4 16 4h-4z"
			/>
			<circle cx="9" cy="13" r="2.2" fill="var(--stage)" />
			<circle cx="15" cy="13" r="2.2" fill="var(--stage)" />
			<path fill="var(--stage)" d="M10 19h4v1.5c0 .8-.7 1.5-1.5 1.5h-1c-.8 0-1.5-.7-1.5-1.5V19z" />
		</svg>
	</div>
	<h1 class="title">Lumos</h1>
	<p class="tagline">Kıbrıs yayını aktif.</p>
</div>
<style is:global>
	:root {
		--tr-red: #c8102e;
		--paper: #ffffff;
		--ink: #141414;
		--stage: #121214;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: var(--stage);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(1.25rem, 4vw, 1.75rem);
		padding: clamp(1rem, 4vw, 2rem);
		text-align: center;
	}

	.flag-card {
		width: min(86vw, 420px);
		aspect-ratio: 3 / 2;
		border-radius: 8px;
		overflow: hidden;
		border: 2px solid rgba(255, 255, 255, 0.32);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 16px 40px rgba(0, 0, 0, 0.45);
		line-height: 0;
		background: var(--paper);
	}

	.flag-svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.skull-mark {
		margin: 0.45rem auto 0.15rem;
		color: rgba(255, 255, 255, 0.52);
		line-height: 0;
	}

	.skull-svg {
		display: block;
		width: 26px;
		height: auto;
		margin: 0 auto;
	}

	.title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
	}

	.tagline {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.82);
		max-width: 22rem;
	}

</style>
</body>
</html>
