<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos — Açık mektup</title>
<meta name="description" content="Lumos — Kıbrıs'tan dünyaya açık mektup" />
<link rel="icon" type="image/png" href="/lumos-paradise-icon.png" />
<link rel="apple-touch-icon" href="/lumos-paradise-icon.png" />
</head>
<body>
<div class="page">
	<div class="hero-visual" aria-hidden="true">
		<svg
			class="hero-svg"
			viewBox="0 0 560 300"
			xmlns="http://www.w3.org/2000/svg"
			preserveAspectRatio="xMidYMid meet"
		>
			<defs>
				<linearGradient id="glow-stroke" x1="0%" y1="0%" x2="100%" y2="100%">
					<stop offset="0%" stop-color="#5eead4" stop-opacity="0.92" />
					<stop offset="35%" stop-color="#14b8a6" stop-opacity="0.62" />
					<stop offset="100%" stop-color="#fbbf24" stop-opacity="0.55" />
				</linearGradient>
				<radialGradient id="ocean-globe" cx="36%" cy="40%" r="75%">
					<stop offset="0%" stop-color="#0c2a33" />
					<stop offset="55%" stop-color="#030f14" />
					<stop offset="100%" stop-color="#000508" />
				</radialGradient>
				<radialGradient id="med-sea" cx="45%" cy="45%" r="65%">
					<stop offset="0%" stop-color="#5eead4" stop-opacity="0.55" />
					<stop offset="70%" stop-color="#0e7490" stop-opacity="0.92" />
					<stop offset="100%" stop-color="#0a4f5e" stop-opacity="0.98" />
				</radialGradient>
				<linearGradient id="cyprus-island" x1="0%" y1="0%" x2="100%" y2="100%">
					<stop offset="0%" stop-color="#ffffff" />
					<stop offset="100%" stop-color="#ecfeff" />
				</linearGradient>
				<filter id="cyprus-glow" x="-80%" y="-80%" width="260%" height="260%">
					<feGaussianBlur in="SourceGraphic" stdDeviation="1" result="b" />
					<feMerge>
						<feMergeNode in="b" />
						<feMergeNode in="SourceGraphic" />
					</feMerge>
				</filter>
				<clipPath id="globe-clip">
					<ellipse cx="280" cy="150" rx="200" ry="94" />
				</clipPath>
			</defs>
			<!-- Diyagram dünya: koyu okyanus, birbirinden ayrı renkli kıtalar, üstte parlak Akdeniz -->
			<g clip-path="url(#globe-clip)" class="world-silhouette">
				<ellipse cx="280" cy="150" rx="200" ry="94" fill="url(#ocean-globe)" />
				<ellipse cx="205" cy="152" rx="118" ry="88" fill="rgba(0, 0, 0, 0.22)" />
				<!-- Amerika -->
				<path
					fill="#0d9488"
					stroke="#fbbf24"
					stroke-width="1.25"
					d="M 96 160 C 78 95 118 48 172 55 C 216 62 230 108 218 152 C 208 192 182 232 152 240 C 112 248 82 218 76 178 C 72 142 82 118 96 160 Z"
				/>
				<!-- Afrika -->
				<path
					fill="#14532d"
					stroke="#fbbf24"
					stroke-width="1.15"
					d="M 226 92 C 258 80 292 95 302 122 C 312 158 302 228 278 248 C 248 262 216 248 206 208 C 196 165 202 118 214 100 C 218 94 222 92 226 92 Z"
				/>
				<!-- Avrupa -->
				<path
					fill="#2dd4bf"
					stroke="#134e4a"
					stroke-width="1.05"
					d="M 246 64 C 278 52 306 62 316 86 C 322 104 298 120 272 116 C 248 110 236 88 236 72 C 236 66 240 64 246 64 Z"
				/>
				<!-- Asya -->
				<path
					fill="#134e4a"
					stroke="#99f6e4"
					stroke-width="1.15"
					d="M 306 72 C 378 58 448 88 468 132 C 488 178 468 212 422 220 C 368 230 318 198 298 152 C 282 118 288 82 306 72 Z"
				/>
				<!-- Avustralya -->
				<path
					fill="#166534"
					stroke="#fbbf24"
					stroke-width="1.05"
					d="M 378 198 C 424 186 452 202 446 236 C 440 258 398 264 372 244 C 354 225 360 205 378 198 Z"
				/>
				<!-- Akdeniz havuzu: kara üstüne açık turkuaz (ada burada okunur) -->
				<ellipse
					cx="294"
					cy="134"
					rx="64"
					ry="30"
					fill="url(#med-sea)"
					stroke="#99f6e4"
					stroke-width="1.25"
				/>
				<!-- Küre grid -->
				<g fill="none" stroke="rgba(255, 255, 255, 0.38)" stroke-width="0.9">
					<ellipse cx="280" cy="150" rx="160" ry="72" />
					<ellipse cx="280" cy="150" rx="122" ry="54" />
					<ellipse cx="280" cy="150" rx="80" ry="34" />
					<path d="M 104 150 H 456" stroke="#fbbf24" stroke-width="1.35" stroke-opacity="0.9" />
					<path d="M 114 116 H 446" />
					<path d="M 114 184 H 446" />
					<path d="M 182 50 Q 280 150 182 250" />
					<path d="M 232 50 Q 280 150 232 250" />
					<path d="M 282 50 Q 280 150 282 250" stroke="#fbbf24" stroke-opacity="0.65" stroke-width="1.05" />
					<path d="M 332 50 Q 280 150 332 250" />
					<path d="M 382 50 Q 280 150 382 250" />
				</g>
			</g>
			<ellipse
				cx="280"
				cy="150"
				rx="200"
				ry="94"
				fill="none"
				stroke="#fbbf24"
				stroke-width="1.5"
				stroke-opacity="0.82"
			/>
			<ellipse
				cx="280"
				cy="150"
				rx="200"
				ry="94"
				fill="none"
				stroke="#5eead4"
				stroke-width="0.7"
				stroke-opacity="0.5"
			/>
			<g class="rays" clip-path="url(#globe-clip)" fill="none" stroke="url(#glow-stroke)" stroke-width="0.72" stroke-linecap="round">
				<line x1="306" y1="139" x2="84.0" y2="131.2" opacity="0.58" />
				<line x1="306" y1="139" x2="248.7" y2="57.2" opacity="0.52" />
				<line x1="306" y1="139" x2="323.2" y2="58.2" opacity="0.5" />
				<line x1="306" y1="139" x2="410.4" y2="78.7" opacity="0.54" />
				<line x1="306" y1="139" x2="452.0" y2="198.0" opacity="0.56" />
				<line x1="306" y1="139" x2="333.2" y2="240.6" opacity="0.52" />
				<line x1="306" y1="139" x2="250.7" y2="243.0" opacity="0.52" />
			</g>
			<!-- Kıbrıs: yatay küçük ada + KD uç; batıda halka/nokta; etiket bağlantı çizgisi -->
			<g class="cyprus-mark">
				<circle cx="274" cy="138" r="9" fill="none" stroke="#fbbf24" stroke-width="1.5" />
				<circle cx="274" cy="138" r="3.6" fill="#ffffff" stroke="#5eead4" stroke-width="0.75" />
				<path
					class="cyprus-shape"
					fill="url(#cyprus-island)"
					stroke="#047857"
					stroke-width="1.35"
					filter="url(#cyprus-glow)"
					d="M 286 133
						L 318 131
						L 322 136
						L 318 142
						L 292 144
						L 284 139
						Z"
				/>
				<path
					fill="url(#cyprus-island)"
					stroke="#047857"
					stroke-width="1.2"
					d="M 316 130 L 336 122 L 340 130 L 328 136 L 320 134 Z"
				/>
				<polyline
					points="326,136 338,142 346,148"
					fill="none"
					stroke="#fbbf24"
					stroke-width="1"
					stroke-linecap="round"
					stroke-linejoin="round"
					opacity="0.85"
				/>
				<text
					x="348"
					y="154"
					fill="#fffbeb"
					font-size="11.5"
					font-weight="700"
					font-family="system-ui, -apple-system, Segoe UI, sans-serif"
					stroke="rgba(2, 8, 12, 0.95)"
					stroke-width="0.55"
					paint-order="stroke fill"
				>
					Kıbrıs
				</text>
			</g>
		</svg>
	</div>

	<h1 class="lumos-wordmark" aria-label="Lumos">Lumos</h1>

	<h2 class="headline">Tüm dünyaya ve insanlığa açık mektup</h2>
	<p class="broadcast-note" role="note">
		Bu yayın, Kıbrıs'tan dünyaya uzanan açık bir çağrı olarak yayımlanmıştır.
	</p>

	<article class="manifesto">
		<p>
			Bugün, Akdeniz'in ortasında, güneşin her yeni gün umutla doğduğu Kıbrıs'tan tüm insanlığa bir el uzatıyoruz.
		</p>
		<p>
			Bizler, geçmişin bilgeliğini ve geleceğin teknolojisini aynı potada buluşturan; adaleti, barışı ve merhameti yalnızca birer söz olarak değil, insanlığa hizmet eden bir teknoloji anlayışı olarak gören bir vizyonun taşıyıcılarıyız.
		</p>
		<p>
			Bu proje, sadece teknolojik bir girişim değil; sınırların, önyargıların ve ayrımcılığın ötesine geçmeyi amaçlayan bir kardeşlik manifestosudur.
		</p>
		<p>
			Kıbrıs'ın bağrından doğan bu ışığı, daha adil, daha dürüst ve daha huzurlu bir dünya umuduyla tüm insanlığa armağan ediyoruz.
		</p>
		<p>
			Gelin; hırsın ve savaşın değil, aklın, merhametin ve vicdanın hüküm sürdüğü yeni bir çağda, el ele vererek tek bir yürek olalım.
		</p>
		<p>
			Bu yazılım bizim imzamız, barış ise ortak geleceğimizdir.
		</p>
	</article>
</div>
<style is:global>
	:root {
		--bg-deep: #060a0e;
		--bg-mid: #0c1419;
		--ink: #e8f4f2;
		--ink-muted: rgba(200, 230, 224, 0.78);
		--paradise-turquoise: #5eead4;
		--paradise-teal: #0d9488;
		--paradise-petrol: #134e4a;
		--paradise-navy: #1e3a5f;
		--paradise-gold: #d4a574;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: radial-gradient(120% 80% at 50% 0%, var(--bg-mid) 0%, var(--bg-deep) 55%, #030508 100%);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	@keyframes ray-pulse {
		0%,
		100% {
			opacity: 0.85;
		}
		50% {
			opacity: 0.45;
		}
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: clamp(1.25rem, 4vw, 2.25rem) clamp(1rem, 4vw, 1.5rem) clamp(2rem, 6vw, 3rem);
		gap: clamp(1rem, 3vw, 1.5rem);
	}

	.hero-visual {
		width: min(92vw, 560px);
		max-height: min(42vh, 300px);
		flex-shrink: 0;
	}

	.hero-svg {
		display: block;
		width: 100%;
		height: auto;
		overflow: visible;
	}

	.hero-svg .rays line {
		animation: ray-pulse 14s ease-in-out infinite;
	}

	.hero-svg .rays line:nth-child(2) {
		animation-delay: -2.5s;
	}
	.hero-svg .rays line:nth-child(3) {
		animation-delay: -5s;
	}
	.hero-svg .rays line:nth-child(4) {
		animation-delay: -3.5s;
	}
	.hero-svg .rays line:nth-child(5) {
		animation-delay: -6s;
	}
	.hero-svg .rays line:nth-child(6) {
		animation-delay: -1.2s;
	}
	.hero-svg .rays line:nth-child(7) {
		animation-delay: -3.8s;
	}

	.lumos-wordmark {
		margin: 0;
		font-size: clamp(2rem, 6.5vw, 2.65rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.12;
		text-align: center;
		color: rgba(241, 245, 249, 0.97);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
	}

	.lumos-wordmark::first-letter {
		color: #7ee7d8;
		font-weight: 800;
		text-shadow:
			0 0 18px rgba(45, 212, 191, 0.4),
			0 1px 2px rgba(0, 0, 0, 0.35);
	}

	.headline {
		margin: 0;
		max-width: 22rem;
		font-size: clamp(1.125rem, 3.8vw, 1.35rem);
		font-weight: 600;
		line-height: 1.35;
		text-align: center;
		color: rgba(212, 165, 116, 0.92);
		letter-spacing: -0.01em;
	}

	.broadcast-note {
		margin: 0.35rem 0 0;
		max-width: 26rem;
		padding: 0 0.5rem;
		font-size: clamp(0.9375rem, 2.6vw, 1.03rem);
		font-weight: 500;
		line-height: 1.45;
		text-align: center;
		color: rgba(204, 251, 241, 0.88);
		letter-spacing: -0.01em;
	}

	.manifesto {
		width: 100%;
		max-width: 38rem;
		margin-top: clamp(0.25rem, 2vw, 0.75rem);
		padding: clamp(1rem, 3vw, 1.35rem) clamp(0.75rem, 3vw, 1rem);
		border-radius: 12px;
		background: rgba(8, 18, 24, 0.45);
		border: 1px solid rgba(94, 234, 212, 0.12);
		box-shadow: 0 20px 48px rgba(0, 0, 0, 0.35);
	}

	.manifesto p {
		margin: 0 0 1rem;
		font-size: clamp(0.9375rem, 2.8vw, 1.0625rem);
		line-height: 1.65;
		color: var(--ink-muted);
		text-align: left;
		overflow-wrap: anywhere;
		hyphens: auto;
	}

	.manifesto p:last-child {
		margin-bottom: 0;
	}
</style>
</body>
</html>
