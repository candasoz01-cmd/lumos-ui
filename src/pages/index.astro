<html>
<head>
<meta charset="UTF-8" />
<title>Julumos</title>
<meta name="description" content="Julumos" />
</head>
<body style="background:#0b1020;color:white;text-align:center;margin-top:100px;font-family:sans-serif;">
<h1>Julumos</h1>
<input id="msg" style="width:420px;padding:10px;" placeholder="Sorunu yaz">
<br><br>
<button onclick="sendMessage()">Send</button>
<pre id="out" style="margin:24px auto 0;max-width:700px;text-align:left;white-space:pre-wrap;"></pre>
<script>
async function sendMessage(){
  const out = document.getElementById("out");
  out.innerText = "Gönderiliyor...";
  try {
    const m = document.getElementById("msg").value;
    const r = await fetch("https://lumos-core-2.onrender.com/chat", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body: JSON.stringify({message:m})
    });
    const text = await r.text();
    out.innerText = "HTTP " + r.status + "\n" + text;
  } catch(e) {
    out.innerText = "ERROR: " + e.message;
  }
}
</script>
</body>
</html>
