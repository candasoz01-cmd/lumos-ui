<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos</title>
<meta name="description" content="Lumos — Kıbrıs yayını" />
</head>
<body>
<div class="page">
	<div class="flag-card" role="img" aria-label="KKTC tarzı bayrak: üst-alt kırmızı şerit, ortada hilal ve yıldız">
		<svg
			class="flag-svg"
			viewBox="0 0 300 200"
			width="300"
			height="200"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
			preserveAspectRatio="xMidYMid meet"
		>
			<defs>
				<clipPath id="lumos-white-band">
					<rect x="0" y="22" width="300" height="156" />
				</clipPath>
			</defs>
			<!-- Zemin -->
			<rect width="300" height="200" fill="#ffffff" />
			<!-- Üst / alt şerit (~%11, simetrik) -->
			<rect x="0" y="0" width="300" height="22" fill="#c8102e" />
			<rect x="0" y="178" width="300" height="22" fill="#c8102e" />
			<!-- Ay-yıldız yalnızca beyaz bantta -->
			<g clip-path="url(#lumos-white-band)">
				<!-- Hilal: evenodd — dış kırmızı daire − iç daire (matematiksel kesim) -->
				<path
					fill-rule="evenodd"
					fill="#c8102e"
					d="M 108 100 A 35 35 0 1 1 38 100 A 35 35 0 1 1 108 100 M 131 100 A 30 30 0 1 0 71 100 A 30 30 0 1 0 131 100"
				/>
				<path
					fill="#c8102e"
					transform="rotate(-14 222 100)"
					d="M 222.00 81.50 L 226.41 93.93 L 239.59 94.28 L 229.13 102.32 L 232.87 114.97 L 222.00 107.50 L 211.13 114.97 L 214.87 102.32 L 204.41 94.28 L 217.59 93.93 Z"
				/>
			</g>
		</svg>
	</div>
	<div class="skull-mark" aria-hidden="true">
		<svg class="skull-svg" viewBox="0 0 40 44" xmlns="http://www.w3.org/2000/svg">
			<!-- Siluet: geniş kafa + çene; gözler oval; üçgen burun; diş çizgisi -->
			<path
				fill="currentColor"
				d="M20 5C10 5 4 12 4 21c0 5 2 9 5 11l1 10h6v-7h8v7h6l1-10c3-2 5-6 5-11 0-9-6-16-16-16z"
			/>
			<ellipse cx="14" cy="22" rx="4.8" ry="6" fill="var(--stage)" />
			<ellipse cx="26" cy="22" rx="4.8" ry="6" fill="var(--stage)" />
			<path fill="var(--stage)" d="M20 27.5 L16.5 35 L23.5 35 Z" />
			<path
				fill="none"
				stroke="var(--stage)"
				stroke-width="2"
				stroke-linecap="round"
				d="M14 38h12"
			/>
		</svg>
	</div>
	<h1 class="title">Lumos</h1>
	<p class="tagline">Kıbrıs yayını aktif.</p>
</div>
<style is:global>
	:root {
		--tr-red: #c8102e;
		--paper: #ffffff;
		--ink: #141414;
		--stage: #121214;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: var(--stage);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(1.25rem, 4vw, 1.75rem);
		padding: clamp(1rem, 4vw, 2rem);
		text-align: center;
	}

	.flag-card {
		width: min(86vw, 420px);
		aspect-ratio: 3 / 2;
		border-radius: 8px;
		overflow: hidden;
		border: 2px solid rgba(255, 255, 255, 0.32);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 16px 40px rgba(0, 0, 0, 0.45);
		line-height: 0;
		background: var(--paper);
	}

	.flag-svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.skull-mark {
		margin: 0.45rem auto 0.15rem;
		color: rgba(255, 255, 255, 0.52);
		line-height: 0;
	}

	.skull-svg {
		display: block;
		width: 34px;
		height: auto;
		margin: 0 auto;
	}

	.title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
	}

	.tagline {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.82);
		max-width: 22rem;
	}

</style>
</body>
</html>
