			0 0 18px rgba(45, 212, 191, 0.4),
			0 1px 2px rgba(0, 0, 0, 0.35);
	}

	.headline {
		margin: 0;
		max-width: 22rem;
		font-size: clamp(1.125rem, 3.8vw, 1.35rem);
		font-weight: 600;
		line-height: 1.35;
		text-align: center;
		color: rgba(212, 165, 116, 0.92);
		letter-spacing: -0.01em;
	}

	.broadcast-note {
		margin: 0.35rem 0 0;
		max-width: 26rem;
		padding: 0 0.5rem;
		font-size: clamp(0.9375rem, 2.6vw, 1.03rem);
		font-weight: 500;
		line-height: 1.45;
		text-align: center;
		color: rgba(204, 251, 241, 0.88);
		letter-spacing: -0.01em;
	}

	.manifesto {
		width: 100%;
		max-width: 38rem;
