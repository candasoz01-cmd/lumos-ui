<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos</title>
<meta name="description" content="Lumos — Kıbrıs yayını" />
</head>
<body>
<div class="page">
	<div class="flag-card" role="img" aria-label="KKTC tarzı bayrak: üst-alt kırmızı şerit, ortada hilal ve yıldız">
		<!--
		  KKTC / TR konstrüksiyonu (G=gönder yükseklik, L=1,5G uç):
		  N=G/10 kırmızı şerit; A=G/2 hilal dış merkez mesafesi; B=G/2 dış çap;
		  C=G/16 iki merkez arası; D=2G/5 iç çap; E=G/3 (iç hilal ile yıldız çemberi arası);
		  F=G/4 yıldız çemberi çapı. Kaynak: KKTC bayrak yönetmeliği / TR aynı oranlar.
		-->
		<svg
			class="flag-svg"
			viewBox="0 0 300 200"
			width="300"
			height="200"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
			preserveAspectRatio="xMidYMid meet"
		>
			<defs>
				<clipPath id="lumos-white-band">
					<rect x="0" y="20" width="300" height="160" />
				</clipPath>
			</defs>
			<rect width="300" height="200" fill="#ffffff" />
			<rect x="0" y="0" width="300" height="20" fill="#c8102e" />
			<rect x="0" y="180" width="300" height="20" fill="#c8102e" />
			<g clip-path="url(#lumos-white-band)">
				<path
					fill-rule="evenodd"
					fill="#c8102e"
					d="M 150 100 A 50 50 0 1 1 50 100 A 50 50 0 1 1 150 100 M 152.5 100 A 40 40 0 1 0 72.5 100 A 40 40 0 1 0 152.5 100"
				/>
				<path
					fill="#c8102e"
					d="M 244.167 75.000 L 249.780 92.275 L 267.943 92.275 L 253.248 102.951 L 258.861 120.225 L 244.167 109.549 L 229.472 120.225 L 235.085 102.951 L 220.390 92.275 L 238.554 92.275 Z"
				/>
			</g>
		</svg>
	</div>
	<figure class="gift-skull-wrap">
		<img
			class="gift-skull-img"
			src="/skull-gift.png"
			width="1254"
			height="1254"
			alt="Tüm insanlığa hediye"
			loading="eager"
			decoding="async"
		/>
		<figcaption class="gift-skull-caption">
			Kuzey Kıbrıs'tan tüm insanlığa hediye
		</figcaption>
	</figure>
	<h1 class="title">Lumos</h1>
	<p class="tagline">Kıbrıs yayını aktif.</p>
</div>
<style is:global>
	:root {
		--tr-red: #c8102e;
		--paper: #ffffff;
		--ink: #141414;
		--stage: #121214;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: var(--stage);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(1.25rem, 4vw, 1.75rem);
		padding: clamp(1rem, 4vw, 2rem);
		text-align: center;
	}

	.flag-card {
		width: min(86vw, 420px);
		aspect-ratio: 3 / 2;
		border-radius: 8px;
		overflow: hidden;
		border: 2px solid rgba(255, 255, 255, 0.32);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 16px 40px rgba(0, 0, 0, 0.45);
		line-height: 0;
		background: var(--paper);
	}

	.flag-svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.gift-skull-wrap {
		margin: 0.35rem 0 0;
		padding: 0;
		border: 0;
		max-width: min(86vw, 280px);
		line-height: 0;
	}

	.gift-skull-img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 8px;
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 12px 28px rgba(0, 0, 0, 0.4);
	}

	.gift-skull-caption {
		margin: 0.65rem 0 0;
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.88);
		text-align: center;
	}

	.title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
	}

	.tagline {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.82);
		max-width: 22rem;
	}

</style>
</body>
</html>
