<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lumos</title>
<meta name="description" content="Lumos — Kıbrıs yayını" />
</head>
<body>
<div class="page">
	<div class="flag-card" role="img" aria-label="Kuzey Kıbrıs bayrağına benzer düzen: üst ve alt kırmızı şerit, ortada beyaz alan ve kırmızı ay-yıldız">
		<div class="flag-stripe flag-stripe--top" aria-hidden="true"></div>
		<div class="flag-field">
			<div class="emblem" aria-hidden="true">
				<span class="crescent"></span>
				<span class="star"></span>
			</div>
		</div>
		<div class="flag-stripe flag-stripe--bottom" aria-hidden="true"></div>
	</div>
	<h1 class="title">Lumos</h1>
	<p class="tagline">Kıbrıs yayını aktif.</p>
</div>
<style is:global>
	:root {
		--tr-red: #c8102e;
		--paper: #ffffff;
		--ink: #141414;
		--muted: #3d3d3d;
		--stage: #1c1c1e;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
		background: var(--stage);
		color: var(--ink);
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			Roboto,
			"Helvetica Neue",
			Arial,
			sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(1.25rem, 4vw, 1.75rem);
		padding: clamp(1rem, 4vw, 2rem);
		text-align: center;
	}

	/* Beyaz bayrak kartı — ana odak, daha geniş ve keskin */
	.flag-card {
		width: min(95vw, 28rem);
		max-width: 100%;
		border-radius: 12px;
		overflow: hidden;
		background: var(--paper);
		border: 3px solid rgba(255, 255, 255, 0.45);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35),
			0 28px 60px rgba(0, 0, 0, 0.55),
			0 8px 24px rgba(200, 16, 46, 0.35);
	}

	.flag-stripe {
		height: clamp(3.5rem, 12vw, 5.75rem);
		min-height: 3.25rem;
		background: var(--tr-red);
		box-shadow:
			inset 0 2px 0 rgba(255, 255, 255, 0.18),
			inset 0 -1px 0 rgba(0, 0, 0, 0.12);
	}

	.flag-field {
		min-height: clamp(13rem, 44vw, 19rem);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1.25rem, 5vw, 2rem) clamp(1rem, 4vw, 1.75rem);
		background: var(--paper);
		box-shadow: inset 0 1px 0 rgba(0, 0, 0, 0.06);
	}

	.emblem {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(0.5rem, 2.5vw, 0.85rem);
		filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.12));
	}

	/* Ay — daha büyük, seçilebilir siluet */
	.crescent {
		display: block;
		width: clamp(5.25rem, 26vw, 8rem);
		height: clamp(5.25rem, 26vw, 8rem);
		max-width: min(8rem, 28vw);
		max-height: min(8rem, 28vw);
		border-radius: 50%;
		background: var(--tr-red);
		box-shadow: clamp(0.85rem, 4.5vw, 1.35rem) 0 0 0 var(--paper);
		transform: rotate(-18deg);
		flex-shrink: 0;
	}

	/* Yıldız — ay ile orantılı, daha belirgin */
	.star {
		display: block;
		width: clamp(4.25rem, 20vw, 6.25rem);
		height: clamp(4.25rem, 20vw, 6.25rem);
		max-width: min(6.25rem, 22vw);
		max-height: min(6.25rem, 22vw);
		background: var(--tr-red);
		clip-path: polygon(
			50% 0%,
			61% 35%,
			100% 35%,
			69% 59%,
			82% 100%,
			50% 74%,
			18% 100%,
			31% 59%,
			0% 35%,
			39% 35%
		);
		margin-left: clamp(-0.25rem, -1.2vw, -0.05rem);
		flex-shrink: 0;
	}

	.title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
	}

	.tagline {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.78);
		max-width: 22rem;
	}

</style>
</body>
</html>
